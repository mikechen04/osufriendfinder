<%- include("../partials/head", { title }) %>

<section class="card">
  <p class="est">inbox</p>
  <p class="muted" style="margin: 0 0 1rem">convos (like discord dms)</p>

  <% if (!convos || convos.length === 0) { %>
    <p class="empty">no convos yet. tragic</p>
  <% } else { %>
    <div class="inbox">
      <% convos.forEach(c => { %>
        <div class="msg msg--row <%= c.unread > 0 ? 'unread' : 'read' %>">
          <a class="msg-link" href="/inbox/<%= c.otherId %>?view=both">
            <img class="avatar smol" src="<%= c.avatar_url || 'https://files.catbox.moe/evvmvg.webp' %>" alt="" />
            <div>
              <div class="msg-top">
                <div class="msg-from">
                  <b><%= c.name %></b>
                  —
                  <span class="muted"><%= c.unread > 0 ? (c.unread + ' unread') : 'no unread' %></span>
                </div>
                <div class="msg-time"><%= new Date(c.last_at).toLocaleString() %></div>
              </div>
              <div class="msg-body"><%= c.last_body %></div>
            </div>
          </a>

          <form action="/block" method="post" class="msg-actions">
            <input type="hidden" name="block_user_id" value="<%= c.otherId %>" />
            <input type="hidden" name="redirect_to" value="/inbox" />
            <button class="btn tiny danger" type="submit">block</button>
          </form>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include("../partials/foot") %>
