<%- include("../partials/head", { title }) %>

<section class="card">
  <p class="est">preferences</p>
  <h1 class="h1">settings n stuff</h1>

  <div class="stack-section">
    <div class="stack-item">
      <h3>dating preferences</h3>
      <p>this just filters who shows up on browse</p>

      <form action="/preferences" method="post" class="form" style="margin-top: 0.75rem">
        <%
          // use res.locals.prefs (express makes it available as `prefs` here)
          const p = (typeof prefs !== "undefined" ? prefs : null);
          const minAge = p && typeof p.min_age === "number" ? p.min_age : "";
          const maxAge = p && typeof p.max_age === "number" ? p.max_age : "";
          const genders = p && Array.isArray(p.genders) ? p.genders : [];
          const rankMax = p && typeof p.rank_max === "number" ? p.rank_max : null;
        %>

        <div class="form-row">
          <label for="pref_min_age">preferred min age</label>
          <input
            id="pref_min_age"
            name="pref_min_age"
            type="number"
            min="18"
            max="120"
            placeholder="leave blank"
            value="<%= minAge %>"
          />
          <div class="hint">blank = no min age filter</div>
        </div>

        <div class="form-row">
          <label for="pref_max_age">preferred max age</label>
          <input
            id="pref_max_age"
            name="pref_max_age"
            type="number"
            min="18"
            max="120"
            placeholder="leave blank"
            value="<%= maxAge %>"
          />
          <div class="hint">blank = no max age filter</div>
        </div>

        <div class="form-row">
          <label>preferred genders</label>
          <div class="check-row">
            <label class="check">
              <input type="checkbox" name="pref_genders" value="male" <%= genders.includes("male") ? "checked" : "" %> />
              <span>male</span>
            </label>
            <label class="check">
              <input type="checkbox" name="pref_genders" value="female" <%= genders.includes("female") ? "checked" : "" %> />
              <span>female</span>
            </label>
            <label class="check">
              <input type="checkbox" name="pref_genders" value="enby" <%= genders.includes("enby") ? "checked" : "" %> />
              <span>enby</span>
            </label>
            <label class="check">
              <input type="checkbox" name="pref_genders" value="other" <%= genders.includes("other") ? "checked" : "" %> />
              <span>other</span>
            </label>
          </div>
          <div class="hint">if u dont check anything, it wont filter gender</div>
        </div>

        <div class="form-row">
          <label for="pref_rank">preferred partner rank (osu global)</label>
          <select id="pref_rank" name="pref_rank">
            <option value="any" <%= rankMax == null ? "selected" : "" %>>any rank</option>
            <option value="1" <%= rankMax === 1 ? "selected" : "" %>>#1+</option>
            <option value="100" <%= rankMax === 100 ? "selected" : "" %>>#100+</option>
            <option value="500" <%= rankMax === 500 ? "selected" : "" %>>#500+</option>
            <option value="1000" <%= rankMax === 1000 ? "selected" : "" %>>#1000+</option>
            <option value="5000" <%= rankMax === 5000 ? "selected" : "" %>>#5000+</option>
            <option value="10000" <%= rankMax === 10000 ? "selected" : "" %>>#10000+</option>
            <option value="50000" <%= rankMax === 50000 ? "selected" : "" %>>#50000+</option>
          </select>
          <div class="hint">they need to be at least this good (lower # = better)</div>
        </div>

        <button class="btn tiny" type="submit">save preferences</button>
      </form>
    </div>

    <div class="stack-item">
      <h3>profile</h3>
      <p>edit ur info + discord + all that</p>
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap">
        <a class="btn tiny" href="/profile">open profile</a>
        <a class="btn tiny ghost" href="/profile/edit">edit profile</a>
      </div>
    </div>

    <div class="stack-item">
      <h3>block list</h3>
      <p>ppl u blocked (they wont show on browse or inbox)</p>

      <% if (!blockedUsers || blockedUsers.length === 0) { %>
        <p class="muted" style="margin-top: 0.65rem">empty</p>
      <% } else { %>
        <div class="stack-section" style="margin-top: 0.75rem">
          <% blockedUsers.forEach(u => { %>
            <div class="stack-item" style="margin: 0">
              <div style="display: flex; gap: 0.75rem; align-items: center; justify-content: space-between; flex-wrap: wrap">
                <div style="display: flex; gap: 0.65rem; align-items: center">
                  <img class="avatar smol" src="<%= u.avatar_url || 'https://files.catbox.moe/evvmvg.webp' %>" alt="" />
                  <div>
                    <div style="font-weight: 800"><%= u.username %></div>
                    <a class="softlink" href="https://osu.ppy.sh/users/<%= u.osu_id %>" target="_blank" rel="noreferrer">osu!</a>
                  </div>
                </div>

                <form action="/unblock" method="post" class="inline">
                  <input type="hidden" name="unblock_user_id" value="<%= u.id %>" />
                  <button class="btn tiny ghost" type="submit">unblock</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="stack-item">
      <h3>danger zone</h3>
      <p>this deletes ur profile + messages and logs u out</p>
      <form
        action="/account/destroy"
        method="post"
        onsubmit="return confirm('are u sure? this deletes ur profile + messages and logs u out')"
      >
        <button class="btn danger" type="submit">destroy ur profile</button>
      </form>
    </div>

    <% if (isAdmin) { %>
      <div class="stack-item">
        <h3>admin</h3>
        <p>wipe bios longer than 750 chars</p>
        <form action="/admin/cleanup-bios" method="post" onsubmit="return confirm('run bio cleanup?')">
          <button class="btn tiny danger" type="submit">run bio cleanup</button>
        </form>
      </div>

      <div class="stack-item">
        <h3>message search</h3>
        <p>find dms that contain a word or phrase (admin only)</p>
        <form action="/admin/messages" method="get" class="form" style="margin-top: 0.75rem">
          <div class="form-row">
            <label for="msg_search_q">keyword</label>
            <input id="msg_search_q" name="q" type="text" maxlength="80" placeholder="e.g. discord, slur, etc" />
          </div>
          <button class="btn tiny" type="submit">search messages</button>
        </form>
      </div>

      <div class="stack-item">
        <h3>profile search</h3>
        <p>view any profile by osu id or username</p>
        <form action="/admin/view-profile" method="get" class="form" style="margin-top: 0.75rem">
          <div class="form-row">
            <label for="view_q">osu id or username</label>
            <input id="view_q" name="q" type="text" maxlength="64" placeholder="id or username" required />
          </div>
          <button class="btn tiny" type="submit">view profile</button>
        </form>
      </div>

      <div class="stack-item">
        <h3>wipe user</h3>
        <p>type osu id or username. this deletes them everywhere (be careful)</p>
        <form action="/admin/wipe-user" method="post" class="form" style="margin-top: 0.75rem" onsubmit="return confirm('wipe this user completely?')">
          <div class="form-row">
            <label for="wipe_q">osu id or username</label>
            <input id="wipe_q" name="q" type="text" maxlength="64" placeholder="id or username" required />
          </div>
          <button class="btn tiny danger" type="submit">wipe user</button>
        </form>
      </div>

      <div class="stack-item">
        <h3>reports</h3>
        <p>stuff ppl report (from the browse page)</p>

        <% if (!reports || reports.length === 0) { %>
          <p class="muted" style="margin-top: 0.65rem">none</p>
        <% } else { %>
          <div class="stack-section" style="margin-top: 0.75rem">
            <% reports.forEach(r => { %>
              <div class="stack-item" style="margin: 0">
                <div style="display: flex; gap: 0.75rem; justify-content: space-between; flex-wrap: wrap">
                  <div style="min-width: 220px">
                    <div style="font-weight: 800">
                      from <%= r.from_username || 'unknown' %>
                      <% if (r.from_osu_id) { %>
                        (<a class="softlink" href="https://osu.ppy.sh/users/<%= r.from_osu_id %>" target="_blank" rel="noreferrer">osu</a>)
                      <% } %>
                    </div>
                    <div class="muted" style="margin-top: 0.1rem">
                      about <%= r.to_username || r.to_user_id || 'unknown' %>
                      <% if (r.to_osu_id) { %>
                        (<a class="softlink" href="https://osu.ppy.sh/users/<%= r.to_osu_id %>" target="_blank" rel="noreferrer">osu</a>)
                      <% } %>
                    </div>
                    <div class="muted" style="margin-top: 0.25rem"><%= new Date(r.created_at || Date.now()).toLocaleString() %></div>
                  </div>

                  <form action="/admin/reports/done" method="post" class="inline">
                    <input type="hidden" name="report_id" value="<%= r.id %>" />
                    <button class="btn tiny ghost" type="submit">mark done</button>
                  </form>
                </div>

                <div class="msg-body" style="margin-top: 0.65rem"><%= r.body %></div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
</section>

<%- include("../partials/foot") %>

