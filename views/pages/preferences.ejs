<%- include("../partials/head", { title }) %>

<section class="card">
  <p class="est">preferences</p>
  <h1 class="h1">settings n stuff</h1>

  <div class="stack-section">
    <div class="stack-item">
      <h3>browse filters</h3>
      <p>this just filters who shows up on browse</p>

      <form action="/preferences" method="post" class="form" style="margin-top: 0.75rem">
        <%
          const p = (typeof prefs !== "undefined" ? prefs : null);
          const minAge = p && typeof p.min_age === "number" ? p.min_age : null;
          const maxAge = p && typeof p.max_age === "number" ? p.max_age : null;
          const genders = p && Array.isArray(p.genders) ? p.genders : [];
          const rankMax = p && typeof p.rank_max === "number" ? p.rank_max : null;

          // starting values for the sliders
          const sliderMin = minAge != null ? minAge : 18;
          const sliderMax = maxAge != null ? maxAge : 67;

          const rankOptions = [
            { label: "any", val: "any" },
            { label: "#1+", val: "1" },
            { label: "#100+", val: "100" },
            { label: "#500+", val: "500" },
            { label: "#1000+", val: "1000" },
            { label: "#5000+", val: "5000" },
            { label: "#10000+", val: "10000" },
            { label: "#50000+", val: "50000" },
          ];
        %>

        <!-- hidden age inputs updated by the dual range slider js -->
        <input type="hidden" name="pref_min_age" id="hidden-min-age" value="<%= minAge != null ? minAge : '' %>" />
        <input type="hidden" name="pref_max_age" id="hidden-max-age" value="<%= maxAge != null ? maxAge : '' %>" />

        <div class="form-row">
          <label>preferred age range &nbsp;<span class="age-range-display">(<span id="age-min-label"><%= sliderMin %></span>–<span id="age-max-label"><%= sliderMax %></span>)</span></label>
          <div class="dual-range" style="max-width: 50%">
            <div class="dual-range-track">
              <div class="dual-range-fill" id="age-fill"></div>
            </div>
            <input type="range" class="dual-range-input" id="age-min-slider" min="18" max="67" value="<%= sliderMin %>" />
            <input type="range" class="dual-range-input" id="age-max-slider" min="18" max="67" value="<%= sliderMax %>" />
          </div>
        </div>

        <div class="form-row">
          <label>preferred genders</label>
          <div class="pref-pill-row">
            <% ['male', 'female', 'enby', 'other'].forEach(function(g) { %>
              <label class="pref-pill <%= genders.includes(g) ? 'active' : '' %>">
                <input type="checkbox" name="pref_genders" value="<%= g %>" <%= genders.includes(g) ? 'checked' : '' %> />
                <%= g %>
              </label>
            <% }); %>
          </div>
        </div>

        <div class="form-row">
          <label>preferred rank (osu global)</label>
          <div class="pref-pill-row">
            <% rankOptions.forEach(function(opt) { %>
              <label class="pref-pill <%= (rankMax == null && opt.val === 'any') || String(rankMax) === opt.val ? 'active' : '' %>">
                <input type="radio" name="pref_rank" value="<%= opt.val %>" <%= (rankMax == null && opt.val === 'any') || String(rankMax) === opt.val ? 'checked' : '' %> />
                <%= opt.label %>
              </label>
            <% }); %>
          </div>
        </div>

        <button class="btn tiny" type="submit" style="width: fit-content">save preferences</button>
      </form>
    </div>

    <%- include("../partials/tourney_prefs_block", {
      tourneyKind: "filter",
      tourneyRedirect: "/preferences",
      tourneyPrefs: locals.tSavedFilter,
      tourneyModsList: locals.tourneyModsList,
      tourneySkillsetsList: locals.tourneySkillsetsList,
      tourneyRankRangesList: locals.tourneyRankRangesList,
    }) %>

    <div class="stack-item">
      <h3>profile</h3>
      <p>edit ur info + discord + all that</p>
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap">
        <a class="btn tiny" href="/profile">open profile</a>
        <a class="btn tiny ghost" href="/profile/edit">edit profile</a>
      </div>
    </div>

    <div class="stack-item">
      <h3>block list</h3>
      <p>ppl u blocked (they wont show on browse or inbox)</p>

      <% if (!blockedUsers || blockedUsers.length === 0) { %>
        <p class="muted" style="margin-top: 0.65rem">empty</p>
      <% } else { %>
        <div class="stack-section" style="margin-top: 0.75rem">
          <% blockedUsers.forEach(u => { %>
            <div class="stack-item" style="margin: 0">
              <div style="display: flex; gap: 0.75rem; align-items: center; justify-content: space-between; flex-wrap: wrap">
                <div style="display: flex; gap: 0.65rem; align-items: center">
                  <img class="avatar smol" src="<%= u.avatar_url || 'https://a.ppy.sh/12742221?1773291467.png' %>" alt="" />
                  <div>
                    <div style="font-weight: 800"><%= u.username %></div>
                    <a class="softlink" href="https://osu.ppy.sh/users/<%= u.osu_id %>" target="_blank" rel="noreferrer">osu!</a>
                  </div>
                </div>

                <form action="/unblock" method="post" class="inline">
                  <input type="hidden" name="unblock_user_id" value="<%= u.id %>" />
                  <button class="btn tiny ghost" type="submit">unblock</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="stack-item">
      <h3>danger zone</h3>
      <p>this deletes ur profile + messages and logs u out</p>
      <form
        action="/account/destroy"
        method="post"
        onsubmit="return confirm('are u sure? this deletes ur profile + messages and logs u out')"
      >
        <button class="btn danger" type="submit">destroy ur profile</button>
      </form>
    </div>

  </div>
</section>

<%- include("../partials/foot") %>
