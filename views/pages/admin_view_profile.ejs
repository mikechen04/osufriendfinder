<%- include("../partials/head", { title }) %>

<section class="card<%= user && cute_tint ? " profile-card-cute" : "" %>">
  <p class="est">admin</p>
  <h1 class="h1">profile lookup</h1>

  <a class="btn tiny ghost" href="/admin">back to admin</a>

  <div class="divider">✿</div>

  <% if (!user) { %>
    <p class="empty">user not found</p>
  <% } else { %>
    <div class="profile-block">
      <img class="avatar big" src="<%= user.avatar_url || 'https://a.ppy.sh/12742221?1773291467.png' %>" alt="" />
      <div>
        <div class="user-name"><%= user.username %></div>
        <div class="user-sub">
          <% if (profile && profile.age) { %><span class="tag"><%= profile.age %>+</span><% } %>
          <% if (profile && profile.gender) { %><span class="tag"><%= profile.gender %></span><% } %>
          <% if (user.country_code) { %><span class="tag"><%= user.country_code %></span><% } %>
        </div>
        <a class="softlink" href="https://osu.ppy.sh/users/<%= user.osu_id %>" target="_blank" rel="noreferrer">open osu! profile</a>
      </div>
    </div>

    <% if (profile && profile.bio) { %>
      <div class="stack-item" style="margin-top: 0.85rem">
        <h3>friend finder bio</h3>
        <p><%= profile.bio %></p>
      </div>
    <% } %>

    <% if (profile && profile.tourney_bio) { %>
      <div class="stack-item" style="margin-top: 0.85rem">
        <h3>tourney teammate bio</h3>
        <p><%= profile.tourney_bio %></p>
      </div>
    <% } %>

    <% if (profile && profile.discord) { %>
      <div class="stack-item" style="margin-top: 0.85rem">
        <h3>discord</h3>
        <p><%= profile.discord %></p>
      </div>
    <% } %>

    <% if (prefs) { %>
      <div class="stack-item" style="margin-top: 0.85rem">
        <h3>looking for:</h3>
        <%
          const minAge = typeof prefs.min_age === "number" ? prefs.min_age : null;
          const maxAge = typeof prefs.max_age === "number" ? prefs.max_age : null;
          const genders = Array.isArray(prefs.genders) ? prefs.genders : [];

          let ageLine = "any age";
          if (minAge != null && maxAge != null) ageLine = `${minAge}-${maxAge}`;
          else if (minAge != null) ageLine = `${minAge}+`;
          else if (maxAge != null) ageLine = `up to ${maxAge}`;

          let genderLine = "any gender";
          if (genders.length) genderLine = genders.join(", ");

          let rankLine = "any rank";
          if (typeof prefs.rank_max === "number") rankLine = `#${prefs.rank_max}+`;
        %>
        <p><%= ageLine %> · <%= genderLine %> · <%= rankLine %></p>
      </div>
    <% } %>

    <div class="stack-item" style="margin-top: 0.85rem">
      <h3>inbox conversations</h3>
      <p>latest chats from this user's inbox</p>
      <% if (!convoRows || convoRows.length === 0) { %>
        <p class="muted" style="margin-top: 0.5rem">no conversation history</p>
      <% } else { %>
        <div class="stack-section" style="margin-top: 0.65rem">
          <% convoRows.forEach(c => { %>
            <div class="stack-item" style="margin: 0">
              <div style="display: flex; gap: 0.75rem; justify-content: space-between; align-items: center; flex-wrap: wrap">
                <div style="display: flex; gap: 0.65rem; align-items: center; min-width: 220px">
                  <img class="avatar smol" src="<%= c.avatar_url || 'https://a.ppy.sh/12742221?1773291467.png' %>" alt="" />
                  <div>
                    <div style="font-weight: 800"><%= c.name %></div>
                    <div class="muted" style="font-size: 0.82rem">
                      <%= c.total %> msgs · <%= c.unread %> unread · <%= new Date(c.last_at || Date.now()).toLocaleString() %>
                    </div>
                    <div class="msg-body" style="margin-top: 0.25rem"><%= c.last_body || "(empty)" %></div>
                  </div>
                </div>

                <% if (c.other_id) { %>
                  <a
                    class="btn tiny"
                    href="/admin/messages/thread?a=<%= encodeURIComponent(adminViewUserId) %>&b=<%= encodeURIComponent(c.other_id) %>"
                  >
                    open thread
                  </a>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="stack-item" style="margin-top: 0.85rem">
      <h3>message history</h3>
      <p>most recent messages in this inbox (newest first)</p>
      <% if (!recentMessages || recentMessages.length === 0) { %>
        <p class="muted" style="margin-top: 0.5rem">no messages</p>
      <% } else { %>
        <div class="inbox" style="margin-top: 0.65rem">
          <% recentMessages.forEach(m => { %>
            <%
              // for "out" (sent by viewed user): show the viewed user's avatar on the left
              // for "in" (received by viewed user): show the sender's (other person's) avatar
              var msgAvatar = m.dir === "out"
                ? (user && user.avatar_url ? user.avatar_url : "https://a.ppy.sh/12742221?1773291467.png")
                : (m.other_avatar_url || "https://a.ppy.sh/12742221?1773291467.png");
              var senderName = m.dir === "out" ? (user && user.username ? user.username : "them") : m.other_name;
            %>
            <div class="msg <%= m.dir === 'out' ? 'read' : 'unread' %>">
              <img class="avatar smol" src="<%= msgAvatar %>" alt="<%= senderName %>" />
              <div>
                <div class="msg-top">
                  <div class="msg-from">
                    <b><%= senderName %></b>
                    <span class="muted" style="font-size: 0.8rem">· <%= m.dir === "out" ? "sent" : "received" %></span>
                  </div>
                  <span class="msg-time"><%= new Date(m.created_at || Date.now()).toLocaleString() %></span>
                </div>
                <div class="msg-body"><%= m.body || "(empty)" %></div>
                <% if (m.other_id) { %>
                  <a
                    class="softlink"
                    href="/admin/messages/thread?a=<%= encodeURIComponent(adminViewUserId) %>&b=<%= encodeURIComponent(m.other_id) %>"
                  >
                    open this thread
                  </a>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  <% } %>
</section>

<%- include("../partials/foot") %>

