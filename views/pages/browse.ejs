<%- include("../partials/head", { title }) %>

<%
  const safeJson = JSON.stringify(users || []).replace(/</g, "\\u003c");
  const isTourney = mode === "tourney";
  const canMsgHere =
    me &&
    me.age &&
    me.bio &&
    me.gender &&
    (isTourney ? me.tourney_bio : true);
%>

<section class="card compact">
  <div class="browse-header">
    <div>
      <p class="est">browse</p>
      <h2 class="panel-title" style="margin: 0"><%= isTourney ? "tourney teammate finder" : "friend finder" %></h2>
      <p class="muted" style="margin: 0.35rem 0 0"><%= isTourney ? "find teammates for your next tournament" : "one at a time so u can overthink properly" %></p>
    </div>
    <div style="display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-end">
      <!-- mode toggle -->
      <div class="browse-mode-toggle">
        <a class="btn tiny <%= !isTourney ? '' : 'ghost' %>" href="/browse">friend finder</a>
        <a class="btn tiny <%= isTourney ? '' : 'ghost' %>" href="/browse?mode=tourney">tourney</a>
      </div>
      <div class="pager">
        <button class="btn tiny ghost" type="button" data-browse-prev>prev</button>
        <div class="pager-text"><span data-browse-idx>1</span>/<span data-browse-total><%= (users || []).length %></span></div>
        <button class="btn tiny" type="button" data-browse-next>next</button>
      </div>
    </div>
  </div>
</section>

<section
  class="card"
  data-browse-root
  data-users-json="<%= safeJson %>"
  data-browse-mode="<%= isTourney ? 'tourney' : 'friend' %>"
>
  <div class="profile-block">
    <img
      class="avatar big"
      data-browse-avatar
      src="https://a.ppy.sh/12742221?1773291467.png"
      alt=""
    />
    <div>
      <div class="user-name" data-browse-name>loading...</div>
      <div class="user-sub" data-browse-tags></div>
      <a class="softlink" data-browse-osu-link href="#" target="_blank" rel="noreferrer">open osu! profile</a>
    </div>
  </div>

  <% if (!isTourney) { %>
    <!-- friend finder: bio + their prefs -->
    <div class="bio big" data-browse-bio></div>
    <div class="stack-item" style="margin-top: 0.75rem">
      <div class="mini-label">preferences</div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.35rem" data-browse-their-prefs></div>
    </div>
  <% } else { %>
    <!-- tourney mode: bio + tourney info -->
    <div class="bio big" data-browse-bio></div>
    <div class="stack-item" style="margin-top: 0.75rem">
      <div class="mini-label">discord</div>
      <p style="margin: 0.35rem 0 0" data-browse-tourney-discord class="muted"></p>
    </div>
    <div class="stack-item" style="margin-top: 0.75rem">
      <div class="mini-label">mods</div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.35rem" data-browse-tourney-mods></div>
    </div>
    <div class="stack-item" style="margin-top: 0.5rem">
      <div class="mini-label">skillsets</div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.35rem" data-browse-tourney-skillsets></div>
    </div>
    <div class="stack-item" style="margin-top: 0.5rem">
      <div class="mini-label">rank range</div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.35rem" data-browse-tourney-ranks></div>
    </div>
  <% } %>

  <div class="divider">✿</div>

  <% if (me) { %>
    <div class="sticky-actions">
      <button class="btn tiny ghost" type="button" data-open-report>report</button>
      <form action="/block" method="post" class="inline">
        <input type="hidden" name="block_user_id" data-browse-block-user-id value="" />
        <input type="hidden" name="redirect_to" value="/browse<%= isTourney ? '?mode=tourney' : '' %>">
        <button class="btn tiny danger" type="submit">block</button>
      </form>
    </div>
  <% } %>

  <% if (canMsgHere) { %>
    <form class="messagebox" action="/message/send" method="post">
      <input type="hidden" name="to_user_id" data-browse-to-user-id value="" />
      <label class="mini-label" for="browse-msg-body">send a message</label>
      <textarea
        id="browse-msg-body"
        name="body"
        rows="3"
        maxlength="500"
        placeholder="如果妳是3 我就是9 因為除了你還是你"
        required
      ></textarea>
      <button class="btn" type="submit">send</button>
    </form>
  <% } else { %>
    <div class="notice">
      <div class="notice-title">u can browse, but u cant message yet</div>
      <div class="notice-text">
        <% if (isTourney) { %>
          finish ur profile + tourney teammate description in edit profile
        <% } else { %>
          finish ur profile first (age + gender + friend finder description)
        <% } %>
      </div>
    </div>
  <% } %>
</section>

<div class="modal-backdrop" data-report-backdrop hidden>
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="report-title">
    <div class="modal-top">
      <div id="report-title" class="panel-title" style="margin: 0">report user</div>
      <button class="linklike" type="button" data-close-report>close</button>
    </div>

    <form action="/report" method="post" class="form">
      <input type="hidden" name="to_user_id" data-report-to-user-id value="" />
      <div class="form-row">
        <label for="report_body">what happened</label>
        <textarea id="report_body" name="body" rows="4" maxlength="500" placeholder="type details..." required></textarea>
        <div class="hint">this sends to the admin (not public)</div>
      </div>
      <button class="btn tiny danger" type="submit">send report</button>
    </form>
  </div>
</div>

<section class="card compact">
  <p class="est">tips</p>
  <div class="rules-grid">
    <div class="rule-box">
      <h4>tiny rules</h4>
      <ul>
        <li>be respectful</li>
        <li>i can not emphasize this enough 18+ only</li>
        <li>if they say no, u say ok</li>
      </ul>
    </div>
    <div class="rule-box">
      <h4>icebreakers</h4>
      <ul>
        <li>meow meow something arf</li>
        <li>你是中国人吗?</li>
        <li>喵喵喵喵喵</li>
      </ul>
    </div>
  </div>
</section>

<%- include("../partials/foot") %>
