<%- include("../partials/head", { title }) %>

<section class="card<%= me && me.cute_tint ? " profile-card-cute" : "" %>">
  <p class="est">profile</p>
  <h1 class="h1">meow arf awruff</h1>

  <form id="profile-edit-form" action="/profile" method="post" class="form">
    <div class="form-row">
      <label for="display_name">display name (optional)</label>
      <input
        id="display_name"
        name="display_name"
        type="text"
        maxlength="40"
        placeholder="display name"
        value="<%= me && me.display_name ? me.display_name : '' %>"
      />
      <div class="hint">shown on your profile view page</div>
    </div>

    <div class="form-row">
      <label for="age">age</label>
      <input
        id="age"
        name="age"
        type="number"
        min="18"
        max="120"
        value="<%= me && me.age ? me.age : 18 %>"
        required
      />
      <div class="hint">18+ only. please dont lie</div>
    </div>

    <div class="form-row">
      <label for="gender">gender</label>
      <select id="gender" name="gender" required>
        <option value="" disabled <%= !me || !me.gender ? "selected" : "" %>>pick one</option>
        <option value="male" <%= me && me.gender === "male" ? "selected" : "" %>>male</option>
        <option value="female" <%= me && me.gender === "female" ? "selected" : "" %>>female</option>
        <option value="enby" <%= me && me.gender === "enby" ? "selected" : "" %>>enby</option>
        <option value="other" <%= me && me.gender === "other" ? "selected" : "" %>>other</option>
      </select>
      <div class="hint">shown next to ur age when ppl browse</div>
    </div>

    <div class="form-row">
      <label for="bio">friend finder description</label>
      <textarea
        id="bio"
        name="bio"
        maxlength="750"
        rows="6"
        placeholder="ex: looking for friends, casual hangout chat..."
        required
      ><%= me && me.bio ? me.bio : "" %></textarea>
      <div class="hint">shown in friend finder browse</div>
    </div>

    <div class="form-row">
      <label for="discord">discord (optional)</label>
      <input
        id="discord"
        name="discord"
        type="text"
        maxlength="64"
        placeholder="discord"
        value="<%= me && me.discord ? me.discord : '' %>"
      />
      <div class="hint">shown on ur profile + in tourney browse when u list it</div>
    </div>

  </form>

  <div class="divider">✿</div>

  <div class="stack-section">
    <div class="stack-item">
      <div class="form-row" style="margin-top: 0">
        <label for="tourney_bio">tourney teammate description</label>
        <textarea
          id="tourney_bio"
          name="tourney_bio"
          maxlength="750"
          rows="6"
          placeholder="ex: lf 4* nm teammate for tourneys, free weekends..."
          required
        ><%= me && me.tourney_bio ? me.tourney_bio : "" %></textarea>
        <div class="hint">shown in tourney teammate browse (can be different from friend finder)</div>
      </div>
    </div>

    <%- include("../partials/tourney_prefs_block", {
      tourneyKind: "profile",
      tourneyRedirect: "/profile/tourney",
      tourneyPrefs: locals.tSavedProfile,
      tourneyModsList: locals.tourneyModsList,
      tourneySkillsetsList: locals.tourneySkillsetsList,
      tourneyRankRangesList: locals.tourneyRankRangesList,
    }) %>
  </div>

  <div class="divider">✿</div>

  <div style="display: flex; gap: 0.6rem; flex-wrap: wrap; align-items: center">
    <button class="btn profile-save-btn" type="submit" form="profile-edit-form">save profile</button>
    <form
      action="/account/destroy"
      method="post"
      onsubmit="return confirm('are u sure? this deletes ur profile + messages and logs u out')"
      class="inline"
    >
      <button class="btn danger" type="submit">destroy ur profile</button>
    </form>
  </div>
</section>

<%- include("../partials/foot") %>
