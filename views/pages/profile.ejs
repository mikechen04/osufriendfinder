<%- include("../partials/head", { title }) %>

<section class="card">
  <p class="est">profile</p>
  <h1 class="h1">meow arf awruff</h1>

  <form action="/profile" method="post" class="form">
    <div class="form-row">
      <label for="display_name">display name (optional)</label>
      <input
        id="display_name"
        name="display_name"
        type="text"
        maxlength="40"
        placeholder="display name"
        value="<%= me && me.display_name ? me.display_name : '' %>"
      />
      <div class="hint">shown on your profile view page</div>
    </div>

    <div class="form-row">
      <label for="age">age</label>
      <input
        id="age"
        name="age"
        type="number"
        min="18"
        max="120"
        value="<%= me && me.age ? me.age : 18 %>"
        required
      />
      <div class="hint">18+ only. please dont lie</div>
    </div>

    <div class="form-row">
      <label for="gender">gender</label>
      <select id="gender" name="gender" required>
        <option value="" disabled <%= !me || !me.gender ? "selected" : "" %>>pick one</option>
        <option value="male" <%= me && me.gender === "male" ? "selected" : "" %>>male</option>
        <option value="female" <%= me && me.gender === "female" ? "selected" : "" %>>female</option>
        <option value="enby" <%= me && me.gender === "enby" ? "selected" : "" %>>enby</option>
        <option value="other" <%= me && me.gender === "other" ? "selected" : "" %>>other</option>
      </select>
      <div class="hint">shown next to ur age when ppl browse</div>
    </div>

    <div class="form-row">
      <label for="bio">description</label>
      <textarea
        id="bio"
        name="bio"
        maxlength="750"
        rows="6"
        placeholder="ex: looking for a duo who won't abandon me after 1 bad map..."
        required
      ><%= me && me.bio ? me.bio : "" %></textarea>
      <div class="hint">shown to others when people browse</div>
    </div>

    <div class="form-row">
      <label for="discord">discord (optional)</label>
      <input
        id="discord"
        name="discord"
        type="text"
        maxlength="64"
        placeholder="discord"
        value="<%= me && me.discord ? me.discord : '' %>"
      />
      <div class="hint">shown on your profile only (for now)</div>
    </div>

    <div class="profile-save-wrap">
      <button class="btn profile-save-btn" type="submit">save profile</button>
    </div>
  </form>

  <div class="divider">✿</div>

  <form
    action="/account/destroy"
    method="post"
    onsubmit="return confirm('are u sure? this deletes ur profile + messages and logs u out')"
  >
    <button class="btn danger" type="submit">destroy ur profile</button>
  </form>
</section>

<%- include("../partials/foot") %>
