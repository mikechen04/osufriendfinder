PORT=3000

# osu! oauth — callback url on osu must be exactly this (including /callback)
# https://osu.ppy.sh/home/account/edit
# add both local + cloud run urls in osu if you use both
OSU_CLIENT_ID=12345
OSU_CLIENT_SECRET=your_secret_here
OSU_REDIRECT_URI=http://localhost:3000/auth/osu/callback

# cloud run (production) — use this as OSU_REDIRECT_URI when deployed there
# https://osudatingmeow-git-57346811168.us-east1.run.app/auth/osu/callback
# live site: https://osudatingmeow-git-57346811168.us-east1.run.app

# firebase realtime database (server-side)
FIREBASE_DATABASE_URL=https://osu-dating-thing-default-rtdb.firebaseio.com
# local dev: point this to your downloaded admin sdk json file
FIREBASE_SERVICE_ACCOUNT_PATH=C:\\Users\\you\\Downloads\\your-firebase-adminsdk.json

# cloud firestore — shared sessions so osu oauth works when cloud run has multiple instances
# 1) firebase console → build → firestore database → create (same project as rtdb)
# 2) cloud run: set USE_FIRESTORE_SESSIONS=1 (and keep same FIREBASE_* / service account as rtdb)
# optional: FIRESTORE_SESSION_COLLECTION=express_sessions
USE_FIRESTORE_SESSIONS=0

# optional: how long session cookie + firestore row live (default 14 days)
# SESSION_MAX_AGE_MS=1209600000

# emergency owner login (only if osu oauth is dying)
# set this to a long random string in cloud run env vars
ADMIN_EMERGENCY_CODE=change_me

# second admin emergency (osu id 12742221) — separate secret from owner
ADMIN_EMERGENCY_CODE_FOID=change_me_foid

# read-only / maintenance: 1 = logins still work; normal users cant send dms / save prefs or profile / block / etc (staff bypasses)
SITE_READ_ONLY=0
